rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // دالة للتحقق من أن المستخدم مدير عام
    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('role', 'admin') == 'super_admin';
    }

    // دالة للتحقق من أن المستخدم مدير
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
             (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('role', 'admin') == 'admin' || isSuperAdmin());
    }
    
    // دالة للتحقق من أن المستهدف هو مدير عام
    function isTargetSuperAdmin() {
      return resource != null && resource.data.get('role', 'admin') == 'super_admin';
    }
    
    // دالة للتحقق من ملكية المحتوى أو إن كان مدير
    function isOwnerOrAdmin() {
      return isAdmin() || (resource.data.createdByUid == request.auth.uid);
    }

    match /videos/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwnerOrAdmin();
    }
    
    match /pdfs/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwnerOrAdmin();
    }
    
    match /posts/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isOwnerOrAdmin();
    }
    
    match /subjects/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }
    
    // قواعد الحماية للمستخدمين مع حماية المؤسس
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.auth.uid == userId ||
        (isAdmin() && request.resource.data.get('role', 'contributor') != 'super_admin') || 
        isSuperAdmin()
      );
      
      allow update: if request.auth != null && (
        isSuperAdmin() ||
        (isAdmin() && !isTargetSuperAdmin() && request.resource.data.get('role', '') != 'super_admin') ||
        (request.auth.uid == userId && request.resource.data.get('role', 'admin') == resource.data.get('role', 'admin'))
      );
      
      allow delete: if request.auth != null && (
        isSuperAdmin() || 
        (isAdmin() && !isTargetSuperAdmin())
      );
    }
  }
}

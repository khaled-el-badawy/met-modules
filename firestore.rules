rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // يسمح للجميع بقراءة المحتوى (الفيديوهات، الملفات، البوستات)
    // يسمح فقط للمستخدم المسجل بالكتابة والتعديل والحذف
    
    match /videos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /pdfs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /posts/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
